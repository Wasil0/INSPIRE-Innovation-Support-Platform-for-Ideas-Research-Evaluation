__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environment — never copy this, Docker installs its own
venv/
env/
.venv/

# Secrets — injected via HuggingFace Space environment variables
.env

# Development/editor files
.vscode/
.idea/
*.suo

# Git
.git/
.gitignore

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# AI cache directories (large, not needed at runtime)
ai/__pycache__/
*.faiss
*.pkl
